<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}HomeCloud{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
        {{ importmap('app') }}
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="bg-red-500 text-gray-900 dark:text-slate-100 min-h-screen transition-colors">
        {# SVG filters (Liquid Glass) #}
        <svg class="hidden" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <filter id="lg">
                    <feTurbulence type="fractalNoise" baseFrequency="0.55 0.65" numOctaves="2" seed="5"/>
                    <feDisplacementMap in="SourceGraphic" scale="6" xChannelSelector="R" yChannelSelector="G"/>
                </filter>
            </defs>
        </svg>

        {# Affichage global des messages flash #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <twig:FlashMessage :type="label" :message="message" />
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </body>
</html>
