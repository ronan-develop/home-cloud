{% extends 'base.html.twig' %}

{% block title %}Choisir un nouveau mot de passe{% endblock %}

{% block body %}
<div class="login-wrapper">
  <div class="login-card"
       data-controller="reset-password-confirm"
       data-reset-password-confirm-token-value="{{ token }}"
       data-reset-password-confirm-login-url-value="{{ path('app_login') }}">

    <div class="login-header">
      <h1 class="login-title">Choisir un nouveau mot de passe</h1>
    </div>

    <form class="login-form" data-reset-password-confirm-target="form" data-action="submit->reset-password-confirm#submit">
      <div>
        <label class="form-label" for="password">Nouveau mot de passe</label>
        <input class="input" type="password" id="password" name="password" required
               placeholder="••••••••" data-reset-password-confirm-target="password">
      </div>

      <button type="submit" class="btn btn-primary login-submit">Réinitialiser</button>
    </form>

    <div class="reset-password-message" data-reset-password-confirm-target="message"></div>
  </div>
</div>
{% endblock %}
