{# Macros d'icônes Heroicons réutilisables #}

{% macro icon(name, size, variant) %}
    {% set size = size ?? 16 %}
    {% set variant = variant ?? 'stroke' %}
    {% set fill = variant == 'solid' ? 'currentColor' : 'none' %}
    {% set stroke = variant == 'stroke' ? 'currentColor' : 'none' %}
    {% set strokeWidth = variant == 'solid' ? 0 : 2 %}

    <svg width="{{ size }}" height="{{ size }}" fill="{{ fill }}" stroke="{{ stroke }}" stroke-width="{{ strokeWidth }}" viewBox="0 0 24 24" class="hc-icon hc-icon-{{ name }}">
        {% if name == 'folder' %}
            <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/>
        {% elseif name == 'cloud' %}
            <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4c-1.48 0-2.85.43-4.01 1.17l1.46 1.46C10.21 5.23 11.08 5 12 5c3.04 0 5.5 2.46 5.5 5.5v.5H19c2.21 0 4 1.79 4 4 0 2.05-1.53 3.76-3.56 3.97l1.07-1.07M9 13h8v-2c0-1.66-1.34-3-3-3-1.66 0-3 1.34-3 3v2m0 6H3V9h6v10z"/>
        {% elseif name == 'images' %}
            <path d="M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        {% elseif name == 'video' %}
            <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
        {% elseif name == 'file' %}
            <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>
        {% elseif name == 'music' %}
            <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
        {% elseif name == 'package' %}
            <path d="M16.5 9.4l-9-5.19"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
        {% endif %}
    </svg>
{% endmacro %}
