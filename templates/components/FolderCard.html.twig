{# Composant FolderCard — Carte dossier #}
<div class="folder-card">
	<a href="{{ path('app_home', { folder: item.id }) }}" class="block">
		<div class="folder-icon">📁</div>
		<div class="folder-name">{{ item.name }}</div>
	</a>
	<div class="folder-actions flex justify-end items-center mt-2 gap-2">
		<button type="button"
		        data-testid="rename-folder-btn-{{ item.id }}"
		        class="rename-btn p-2 rounded-lg text-gray-400 hover:text-green-600 hover:bg-green-50 dark:hover:bg-green-950/40 transition-colors"
		        title="Renommer"
		        data-folder-id="{{ item.id }}">✏️</button>
		<button type="button"
		        data-testid="move-folder-btn-{{ item.id }}"
		        class="move-btn p-2 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-colors"
		        title="Déplacer"
		        onclick="openGlobalMoveModal('folder', '{{ item.id }}', '{{ item.name|e('js') }}')">↪️</button>
	</div>
</div>
{# Props attendues : item (entité Folder) #}
