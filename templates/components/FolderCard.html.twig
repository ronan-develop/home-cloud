{# Composant FolderCard — Carte dossier ou fichier enrichie #}
<div class="folder-card">
	{% if item.mimeType is not defined or item.mimeType is null %}
		{# C'est un dossier (Folder) — n'a pas de mimeType #}
		<div class="folder-icon">📁</div>
		<div class="folder-name">{{ item.name }}</div>
		<div class="folder-actions flex justify-end items-center mt-2 gap-2">
			<button type="button" data-testid="move-folder-btn-{{ item.id }}" class="move-btn p-2 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-colors" title="Déplacer" onclick="openMoveElementModal('move-modal-folder-{{ item.id }}')">↪️</button>
		</div>
	{% else %}
		{# C'est un fichier (File) — a un mimeType #}
		<div class="file-icon">
			{% if item.mimeType starts with 'image/' %}🖼️
				{% elseif item.mimeType starts with 'video/' %}🎬
				{% elseif item.mimeType starts with 'audio/' %}🎵
				{% elseif item.mimeType == 'application/pdf' %}📄
				{% else %}📎
			{% endif %}
		</div>
		<div class="file-name">{{ item.originalName ?? item.name }}</div>
		<div class="file-meta">
			{% if item.size is defined %}
				{{ item.size | number_format(0, ',', ' ') }}
				o ·
			{% endif %}
			{% if item.createdAt is defined %}
				{{ item.createdAt | date('d/m/Y') }}
			{% endif %}
			{% if item.isNeutralized is defined and item.isNeutralized %}
				<span class="text-amber-500 ml-1" title="Fichier neutralisé">⚠️</span>
			{% endif %}
		</div>
		<div class="file-actions" style="margin-top:0.7rem; display:flex; gap:0.5rem;">
			{% if item.id is defined %}
				<a href="{{ path('app_file_download', { id: item.id }) }}" class="p-2 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-colors" title="Télécharger">⬇️</a>
				<form method="post" action="{{ path('app_file_delete', { id: item.id }) }}" onsubmit="return confirm('Supprimer « {{ item.originalName|e('js') }} » ?')">
					<input type="hidden" name="folder_id" value="{{ item.folderId ?? '' }}">
					<button type="submit" class="delete-btn p-2 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-950/40 transition-colors" title="Supprimer">🗑️</button>
				</form>
				<button type="button" data-testid="move-file-btn-{{ item.id }}" class="move-btn p-2 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-colors" title="Déplacer" onclick="openMoveElementModal('move-modal-file-{{ item.id }}')">↪️</button>
			{% endif %}
		</div>
	{% endif %}
</div>
{# Props attendues : item (objet dossier/fichier) #}
