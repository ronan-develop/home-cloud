{# Version minimale pour TDD RED #}

<div class="lg-card font-bold">Dossiers</div>
{% macro render_tree(nodes, level) %}
	{% for node in nodes %}
		<div class="lg-card" style="margin-left: {{ level * 24 }}px">{{ node.name }}</div>
		{% if node.children|length > 0 %}
			{{ _self.render_tree(node.children, level + 1) }}
		{% endif %}
	{% endfor %}
{% endmacro %}

{% import _self as tree %}
{{ tree.render_tree(tree, 0) }}
