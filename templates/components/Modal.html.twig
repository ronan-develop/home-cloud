{# Composant Modal générique — structure de base pour toutes les modales #}
{% set sizes = {
  'sm': 'max-w-md',
  'md': 'max-w-xl',
  'lg': 'max-w-2xl',
} %}
<div x-data="{ open: {{ open ? 'true' : 'false' }} }" x-show="open" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-slate-900 rounded-2xl shadow-2xl w-full {{ sizes[size|default('md')] }} p-8 relative animate-fade-in" @click.away="open = false">
    <button @click="open = false" class="absolute top-4 right-4 text-white/60 hover:text-white text-2xl focus:outline-none">&times;</button>
    {% if icon %}<div class="mb-4 text-4xl">{{ icon|raw }}</div>{% endif %}
    <h2 class="text-xl font-bold text-white mb-2">{{ title }}</h2>
    <div class="text-white/80 mb-6">
      {% if content %}{{ content|raw }}{% else %}{% block modal_content %}{% endblock %}{% endif %}
    </div>
    <div class="flex gap-3 justify-end">
      {% for action in actions %}
        <twig:Button
          :label="action.label"
          :variant="action.variant ?? 'primary'"
          :icon="action.icon ?? null"
          :type="action.type ?? 'button'"
          :href="action.href ?? null"
          :form="action.form ?? null"
        />
      {% endfor %}
    </div>
  </div>
</div>
{# Props : title, icon, size, open, content, actions, id #}
