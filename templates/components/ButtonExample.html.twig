{# Exemple d'utilisation du composant Button #}
<div class="flex gap-4 items-center p-6 bg-slate-800 rounded-2xl">
  <twig:Button label="Valider" icon="<span>✔️</span>" variant="primary" />
  <twig:Button label="Annuler" variant="secondary" />
  <twig:Button label="Supprimer" icon="<span>🗑️</span>" variant="danger" size="sm" />
  <twig:Button label="Voir la doc" href="https://github.com" icon="<span>📖</span>" variant="primary" size="lg" />
</div>
