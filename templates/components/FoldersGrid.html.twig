{# Composant FoldersGrid — Grille de dossiers/fichiers #}
<div class="folders-grid">
  {% for item in items %}
    <twig:FolderCard :item="item" />
  {% else %}
    <twig:EmptyState
      title="Aucun fichier ni dossier"
      subtitle="Glissez un fichier ou créez un dossier pour commencer."
      icon="<span style='font-size:3rem;opacity:0.5;'>📂</span>"
    />
  {% endfor %}
</div>
{# Props attendues : items (liste de fichiers/dossiers) #}
