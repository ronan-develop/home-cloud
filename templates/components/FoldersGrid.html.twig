{# Composant FoldersGrid — Grille de dossiers et fichiers #}
<div class="folders-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  {% if folders is empty and files is empty %}
    <twig:EmptyState
      title="Aucun fichier ni dossier"
      subtitle="Glissez un fichier ou créez un dossier pour commencer."
      icon="<svg style='font-size:3rem;opacity:0.5;' width='64' height='64' fill='none' stroke='currentColor' stroke-width='1.5' viewBox='0 0 24 24' class='hc-icon hc-icon-folder'><path d='M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z'/></svg>"
    />
  {% else %}
    {% for folder in folders %}
      <twig:FolderCard :item="folder" />
    {% endfor %}
    {% for file in files %}
      <twig:FileCard :item="file" />
    {% endfor %}
  {% endif %}
</div>
{# Props attendues : folders (liste Folder[]), files (liste File[]) #}
