{% extends "base.html.twig" %}
{% block title %}Upload a photo{% endblock %}


{% block body %}

    {% include "partials/_navbar.html.twig" %}

    <div class="container mx-auto">

        <h1 class="p-4 m-4">Upload a photo</h1>
        <div class="card bg-white p-4 m-4 rounded-lg shadow-md">
            {{ form_start(form, {'attr': {'class': 'w-full max-w-lg'}}) }}
            {{ form_row(form.url, {
                    class: 'w-full px-3 mb-6',
                    label_class: "block tracking-wide text-gray-700 text-xs font-bold mb-2"
            
                })
            }}
        {{ form_end(form) }}
        </div>
    </div>
{% endblock %}