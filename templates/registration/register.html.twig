{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    {% include 'partials/_navbar.html.twig' %}
    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <div class="container mx-auto py-4 px-4">

        <h1 class="text-2xl font-bold py-2">Register</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}

        <div class="flex flex-col">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-2 mt-2 border rounded-md'}}) }}
        </div>

        <div class="flex flex-col">
            {{ form_label(registrationForm.plainPassword) }}
            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-2 mt-2 border rounded-md'}}) }}
        </div> 

        {# {{ form_row(registrationForm.agreeTerms) }} #}

        <button type="submit" class="
            px-4
            py-2
            mt-4
            rounded-md
            text-white
            shadow-md
            bg-gray-900
            hover:bg-gray-700">
        Valider
        </button>
    {{ form_end(registrationForm) }}
    </div>
{% endblock %}
