{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}

    {% if app.session.flashBag.has('success') %}

        <div class="alert alert-success">
            {{ app.session.flashBag.get('success')[0] }}
        </div>

    {% endif %}

    {% if app.user %}

        <div class="fixed top-0 left-0 w-full bg-black text-white text-center py-4">
            You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}" class="text-blue-300">Logout</a>
        </div>
        <div class="container mx-auto mt-16">
            <h1 class="text-4xl text-center">Home-Cloud</h1>
        </div>

    {% endif %}

{% endblock %}
