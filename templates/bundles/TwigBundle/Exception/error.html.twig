{% extends 'base.html.twig' %}
{% import 'macros/icon.html.twig' as icons %}

{% block title %}Erreur {{ status_code }} — HomeCloud{% endblock %}

{% block body %}
<div data-testid="error-page" class="hc-error-page">
    <div class="hc-error-icon">
        {{ icons.icon('alert-triangle', 48) }}
    </div>
    <p class="hc-error-code">{{ status_code }}</p>
    <h1 class="hc-error-title">
        {% if status_code == 404 %}
            Page introuvable
        {% elseif status_code == 403 %}
            Accès refusé
        {% elseif status_code == 400 %}
            Requête invalide
        {% elseif status_code == 401 %}
            Authentification requise
        {% elseif status_code >= 500 %}
            Erreur serveur
        {% else %}
            Une erreur est survenue
        {% endif %}
    </h1>
    <p class="hc-error-sub">
        {% if status_code == 404 %}
            La page que vous cherchez n'existe pas ou a été déplacée.
        {% elseif status_code == 403 %}
            Vous n'avez pas les droits nécessaires pour accéder à cette ressource.
        {% elseif status_code == 400 %}
            La requête envoyée est incorrecte.
        {% elseif status_code == 401 %}
            Vous devez vous connecter pour accéder à cette page.
        {% elseif status_code >= 500 %}
            Une erreur inattendue s'est produite. Réessayez dans un instant.
        {% else %}
            {{ status_text }}
        {% endif %}
    </p>
    <a href="{{ path('app_home') }}" data-testid="error-back-home" class="hc-error-link">
        {{ icons.icon('home', 16) }}
        Retour à l'accueil
    </a>
</div>
{% endblock %}
