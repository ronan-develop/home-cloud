{% extends 'web/layout.html.twig' %}

{% block title %}Mes fichiers — HomeCloud{% endblock %}

{% block content %}


{# === ImportCard component === #}
<twig:ImportCard :current-folder="currentFolder ?? null" />

{# === Breadcrumbs component === #}
<twig:Breadcrumbs :segments="[
    { label: 'Tous les fichiers', url: path('app_home') },
    currentFolder ? { label: currentFolder.name, url: null } : null
] | filter(v => v)" />

{# === Explorateur === #}
<div data-testid="file-explorer" class="flex gap-4">

    {# Sidebar dossiers #}
    <aside class="w-48 shrink-0">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-2 mb-2">Dossiers</h3>

        <div style="display:flex; flex-direction:column; gap:0.6rem;">
                 <a href="{{ path('app_home') }}"
                 class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm transition-all
                     {% if currentFolder is null %}bg-blue-50 text-blue-700 dark:bg-blue-950/50 dark:text-blue-300{% else %}text-gray-600{% endif %}"
                 style="{{ currentFolder is null ? '' : 'background:transparent; color:inherit;' }}"
                 onmouseover="if(!this.classList.contains('bg-blue-50')){this.style.background='#e5e7eb';this.style.color='#111827';}"
                 onmouseout="if(!this.classList.contains('bg-blue-50')){this.style.background='transparent';this.style.color='';}">
                  <span>🏠</span> Tous les fichiers
                 </a>

            {% for folder in folders %}
                <a href="{{ path('app_home', { folder: folder.id }) }}"
                   class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm transition-all
                          {% if currentFolder and currentFolder.id == folder.id %}bg-blue-50 text-blue-700 dark:bg-blue-950/50 dark:text-blue-300{% else %}text-gray-600 hover:bg-white/80 hover:text-gray-900{% endif %}">
                    <span>📁</span> {{ folder.name }}
                </a>
            {% endfor %}
        </div>
    </aside>

    {# Liste fichiers #}
    <div class="flex-1" data-testid="file-list">
        {% if currentFolder %}
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('app_home') }}" class="hover:text-blue-600">Accueil</a>
                <span>/</span>
                <span class="font-medium text-gray-700 dark:text-gray-200">{{ currentFolder.name }}</span>
            </div>
        {% endif %}

                <div class="folders-grid">
                    {% if files is empty %}
                        <div class="folder-card" style="grid-column: 1/-1; text-align: center; opacity: 0.7;">
                            <div class="folder-icon">📂</div>
                            <div class="folder-name">Aucun fichier ici</div>
                            <div class="folder-meta">Glissez un fichier pour commencer</div>
                        </div>
                    {% else %}
                        {% for file in files %}
                            <div class="folder-card">
                                <div class="file-icon">
                                    {% if file.mimeType starts with 'image/' %}🖼️
                                    {% elseif file.mimeType starts with 'video/' %}🎬
                                    {% elseif file.mimeType starts with 'audio/' %}🎵
                                    {% elseif file.mimeType == 'application/pdf' %}📄
                                    {% else %}📎{% endif %}
                                </div>
                                <div class="file-name">{{ file.originalName }}</div>
                                <div class="file-meta">
                                    {{ file.size | number_format(0, ',', ' ') }} o · {{ file.createdAt | date('d/m/Y') }}
                                    {% if file.isNeutralized %}<span class="text-amber-500 ml-1" title="Fichier neutralisé">⚠️</span>{% endif %}
                                </div>
                                <div class="file-actions" style="margin-top:0.7rem; display:flex; gap:0.5rem;">
                                    <a href="{{ path('app_file_download', { id: file.id }) }}"
                                         class="p-2 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-colors"
                                         title="Télécharger">⬇️</a>
                                    <form method="post" action="{{ path('app_file_delete', { id: file.id }) }}"
                                                onsubmit="return confirm('Supprimer « {{ file.originalName|e('js') }} » ?')">
                                        <input type="hidden" name="folder_id" value="{{ currentFolder ? currentFolder.id : '' }}">
                                        <button type="submit"
                                                        class="p-2 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-950/40 transition-colors"
                                                        title="Supprimer">🗑️</button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
    </div>

</div>

<script>
// Ajoute la classe drop-active sur dragenter/leave pour feedback visuel
const importCard = document.getElementById('main-import-card');
if(importCard) {
  importCard.addEventListener('dragenter', () => importCard.classList.add('drop-active'));
  importCard.addEventListener('dragleave', () => importCard.classList.remove('drop-active'));
  importCard.addEventListener('drop',      () => importCard.classList.remove('drop-active'));
}
</script>

{% endblock %}

