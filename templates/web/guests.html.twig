{% extends 'web/layout.html.twig' %}

{% block title %}Invités — HomeCloud{% endblock %}

{% block content %}

{% set guestIcon %}<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>{% endset %}

<div class="flex flex-col gap-7 max-w-[1100px] mx-auto h-full" data-controller="guest-management">

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black tracking-tight mb-1 flex items-center gap-2">
        {{ guestIcon }}
        Invités
      </h1>
      <p class="hc-page-sub">{{ guests|length }} compte{{ guests|length != 1 ? 's' : '' }} invité{{ guests|length != 1 ? 's' : '' }}</p>
    </div>
  </div>

  {# Création directe d'un invité, sans passer par un partage. #}
  <form method="post" action="{{ path('app_guest_create') }}" class="hc-item-card hc-guest-create-form"
        data-guest-management-target="createForm" data-action="submit->guest-management#create">
    <input type="hidden" name="_token" value="{{ csrf_token('guest-create') }}">
    <div class="flex-1">
      <label class="hc-guest-create-label">Créer un invité</label>
      <input type="email" name="email" data-testid="guest-create-email" required
             placeholder="ami@example.com" class="hc-guest-create-input"
             data-guest-management-target="createEmail">
    </div>
    <button type="submit" data-testid="guest-create-submit" class="hc-guest-create-submit">
      Créer
    </button>
  </form>

  {% if guests is empty %}
    <div data-testid="guests-empty">
      <twig:EmptyState
        title="Aucun invité"
        subtitle="Les comptes créés automatiquement lors d'un partage vers un email inconnu apparaîtront ici."
        icon="<svg width='64' height='64' fill='none' stroke='currentColor' stroke-width='1.5' viewBox='0 0 24 24' class='hc-icon'><path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/></svg>"
      />
    </div>
  {% else %}
    <div class="hc-item-card hc-guest-list" data-testid="guests-list">
      {% for guest in guests %}
        <div class="hc-guest-row" data-testid="guest-row-{{ guest.id }}" data-guest-management-target="row">
          <div>
            <div class="hc-item-name">{{ guest.displayName }}</div>
            <div class="hc-item-meta">{{ guest.email }} · créé le {{ guest.createdAt|date('d/m/Y') }}</div>
          </div>
          <div class="hc-guest-row-actions">
            <form method="post" action="{{ path('app_guest_edit', { id: guest.id }) }}" class="flex items-center gap-2"
                  data-action="submit->guest-management#edit">
              <input type="hidden" name="_token" value="{{ csrf_token('guest-edit') }}">
              <input type="text" name="displayName" value="{{ guest.displayName }}"
                     data-testid="guest-edit-name-{{ guest.id }}" class="hc-guest-edit-input">
              <button type="submit" class="hc-item-action hc-guest-action-btn">
                Enregistrer
              </button>
            </form>
            <form method="post" action="{{ path('app_guest_delete', { id: guest.id }) }}"
                  data-guest-display-name="{{ guest.displayName|e('html_attr') }}"
                  data-action="submit->guest-management#delete">
              <input type="hidden" name="_token" value="{{ csrf_token('guest-delete') }}">
              <button type="submit" class="hc-item-action hc-item-action--danger hc-guest-action-btn">
                Supprimer
              </button>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>

{% endblock %}
